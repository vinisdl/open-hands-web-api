{
  "openapi": "3.0.0",
  "info": {
    "title": "WS API",
    "version": "1.0.0",
    "description": "API for WebSocket client."
  },
  "paths": {
    "/api/ws": {
      "get": {
        "summary": "Get current connection status and events",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "summary": "Perform an action (connect, disconnect, send) on the WebSocket client",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string"
                  },
                  "message": {
                    "type": "object",
                    "properties": {
                      "action": {
                        "type": "string"
                      },
                      "args": {
                        "type": "object",
                        "properties": {
                          "content": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "content"
                        ]
                      }
                    },
                    "required": [
                      "action",
                      "args"
                    ]
                  },
                  "conversationId": {
                    "type": "string"
                  }
                },
                "required": [
                  "action"
                ],
                "example": {
                  "action": "send",
                  "message": {
                    "action": "message",
                    "args": {
                      "content": "renomeie para ggg.sh"
                    }
                  },
                  "conversationId": "f64e1b8b679e4a669758e668ec1b4e73"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Action performed successfully"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    }
  }
}
